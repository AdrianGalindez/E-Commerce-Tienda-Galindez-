<!-- include header -->
<%- include('include/_headerAdmin') %>
<!-- /include header -->

<main>
<div>
<h1>Gestionar Detalles de Ventas</h1>
</div>
  <table class="table">
    <thead>
      <tr>
        <th scope="col" hidden>#</th>
        <th scope="col">Venta</th>
        <th scope="col">Producto</th>
        <th scope="col">Cantidad</th>
        <th scope="col">Precio Unitario</th>
        <th scope="col">Total</th>
        <th scope="col">Editar</th>
        <th scope="col">Eliminar</th>
      </tr>
    </thead>
    <tbody>
      <% saleDetails.forEach(function(detail) { %>
      <tr>
        <th scope="row" hidden><%= detail._id %></th>

        <td>
          <%= detail.venta ? detail.venta._id : 'N/A' %>
        </td>

        <td>
          <%= detail.producto ? detail.producto.nombre : 'N/A' %>
        </td>

        <td><%= detail.cantidad %></td>
        <td>$ <%= detail.precioUnitario %></td>
        <td>$ <%= detail.cantidad * detail.precioUnitario %></td>

        <td>
          <a href="/update-sale-detail?id=<%= detail._id %>" class="btn btn-success">Editar</a>
        </td>

        <td>
          <a href="/api/sale-details/<%= detail._id %>" class="btn btn-danger delete">Eliminar</a>
        </td>
      </tr>
      <% }); %>
        <tr>
          <td colspan="4" >
          <a href="/create-sale-detail" class="btn btn-primary">Crear Nueva Detalle de Venta</a>
        </td>
      </tr>
    </tbody>
  </table>

</main>


<!-- include footer -->
<%- include('include/_footerAdmin') %>
<!-- /include footer -->