<!-- include header -->
<%- include('../../include/_headerAdmin') %>
<!-- /include header -->



<main>
<div>
<h1>Gestionar Proveedores</h1>
</div>
  <table class="table">
    <thead>
      <tr>
        <th scope="col" hidden>#</th>
        <th scope="col">Nombre</th>
        <th scope="col">Teléfono</th>
        <th scope="col">Dirección</th>
        <th scope="col">Descripcion</th>
        <th scope="col">Editar</th>
        <th scope="col">Eliminar</th>
      </tr>
    </thead>
    <tbody>
      <% providers.forEach(function(provider) { %>
      <tr>
        <th scope="row" hidden><%= provider._id %></th>
        <td><%= provider.nombre %></td>
        <td><%= provider.telefono %></td>
        <td><%= provider.direccion %></td>
        <td><%= provider.descripcion %></td>
        <td>
          <a href="/update-proveedor?id=<%= provider._id %>" class="btn btn-success">Editar</a>
        </td>

        <td>
          <a href="/delete-proveedor/<%= provider._id %>" class="btn btn-danger delete">Eliminar</a>
        </td>
      </tr>
      <% }); %>
        <tr>
          <td colspan="6" >
          <a href="/create-proveedor" class="btn btn-primary">Crear Nuevo Proveedor</a>
        </td>
      </tr>
    </tbody>
  </table>

</main>

<!-- include footer -->
<%- include('../../include/_footerAdmin') %>
<!-- /include footer -->
