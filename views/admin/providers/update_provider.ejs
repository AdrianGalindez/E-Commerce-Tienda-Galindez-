<!-- include header -->
<%- include('../../include/_headerAdmin') %>
<!-- /include header -->


<h1>Editar Proveedor</h1>

<form action="/update-proveedor/<%= provider._id %>" method="POST">

  <div class="form-group">
    <label for="nombre">Nombre</label>
    <input type="text" name="nombre" id="nombre" class="form-control" value="<%= provider.nombre %>" required>
  </div>

  <div class="form-group">
    <label for="telefono">Teléfono</label>
    <input type="text" name="telefono" id="telefono" class="form-control" value="<%= provider.telefono %>">
  </div>

  <div class="form-group">
    <label for="direccion">Dirección</label>
    <input type="text" name="direccion" id="direccion" class="form-control" value="<%= provider.direccion %>">
  </div>

  <button type="submit" class="btn btn-primary mt-2">Actualizar Proveedor</button>

</form>



<!-- include footer -->
<%- include('../../include/_footerAdmin') %>
<!-- /include footer -->