<%- include('../../include/_headerAdmin') %>

<div class="page-wrapper">

  <div class="page-header">
    <h1>Editar Proveedor</h1>
    <p>Actualiza la información del proveedor registrado</p>
  </div>

  <div class="form-card">

    <form action="/update-proveedor/<%= provider._id %>" method="POST" class="provider-form">

      <div class="form-grid">

        <!-- Nombre -->
        <div class="form-group full">
          <label>Nombre del proveedor</label>
          <input
            type="text"
            name="nombre"
            value="<%= provider.nombre %>"
            required
          >
        </div>

        <!-- Teléfono -->
        <div class="form-group">
          <label>Teléfono</label>
          <input
            type="text"
            name="telefono"
            value="<%= provider.telefono %>"
          >
        </div>

        <!-- Dirección -->
        <div class="form-group">
          <label>Dirección</label>
          <input
            type="text"
            name="direccion"
            value="<%= provider.direccion %>"
          >
        </div>
        
        <div class="form-group full">
          <label>Descripción</label>
          <textarea
            name="descripcion"
            rows="3"
            placeholder="Ej: Proveedor de tecnología"
          ><%= provider.descripcion || '' %></textarea>
        </div>

      </div>

      <div class="form-actions">
        <button type="submit">Actualizar proveedor</button>
      </div>

    </form>

  </div>
</div>

<%- include('../../include/_footerAdmin') %>