<%- include('../../include/_headerAdmin') %>

<div class="page-wrapper">

  <div class="page-header">
    <h1>Proveedores</h1>
    <p>Registra nuevos proveedores para gestionar tu cadena de suministro</p>
  </div>

  <div class="form-card">

    <form action="/create-proveedor" method="POST" class="provider-form">

      <div class="form-grid">

  <div class="form-group full">
    <label>Nombre del proveedor</label>
    <input type="text" name="nombre" required>
  </div>

  <div class="form-group">
    <label>Persona de contacto</label>
    <input type="text" name="contacto">
  </div>

  <div class="form-group">
    <label>Teléfono</label>
    <input type="text" name="telefono">
  </div>

  <div class="form-group full">
    <label>Email</label>
    <input type="email" name="email">
  </div>

  <!-- 👇 ESTE NO EXISTÍA -->
  <div class="form-group full">
    <label>Dirección</label>
    <input type="text" name="direccion">
  </div>

  <!-- 👇 NUEVO -->
  <div class="form-group full">
    <label>Descripción</label>
    <textarea name="descripcion" rows="3" placeholder="Ej: Proveedor de tecnología"></textarea>
  </div>

</div>

      <div class="form-actions">
        <button type="submit">Guardar proveedor</button>
      </div>

    </form>

  </div>
</div>

<%- include('../../include/_footerAdmin') %>