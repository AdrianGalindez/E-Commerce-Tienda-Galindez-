<%- include('../../include/_headerAdmin') %>

<div class="page-wrapper">

  <div class="page-header">
    <h1>Crear Nuevo Producto</h1>
    <p>Completa la información del producto para agregarlo al inventario</p>
  </div>

  <div class="form-card">

    <form action="/api/productos" method="POST" enctype="multipart/form-data" class="product-form">

      <!-- GRID PRINCIPAL -->
      <div class="form-grid">

        <!-- Nombre -->
        <div class="form-group full">
          <label>Nombre del producto</label>
          <input type="text" name="nombre" required>
        </div>

        <!-- Descripción -->
        <div class="form-group full">
          <label>Descripción</label>
          <textarea name="descripcion" rows="4" placeholder="Describe el producto..."></textarea>
        </div>

        <!-- Precio costo -->
        <div class="form-group">
          <label>Precio de costo</label>
          <input type="number" step="0.01" name="precioCosto" required>
        </div>

        <!-- Precio venta -->
        <div class="form-group">
          <label>Precio de venta</label>
          <input type="number" step="0.01" name="precio" required>
        </div>

        <!-- Stock -->
        <div class="form-group">
          <label>Stock</label>
          <input type="number" name="stock" required>
        </div>

        <!-- Categoría -->
        <div class="form-group">
          <label>Categoría</label>
          <select name="categoria" required>
            <option value="">Seleccione una categoría</option>
            <% categorias.forEach(c => { %>
              <option value="<%= c._id %>"><%= c.nombre %></option>
            <% }) %>
          </select>
        </div>

        <!-- Marca -->
        <div class="form-group">
          <label>Marca</label>
          <select name="marca" required>
            <option value="">Seleccione una marca</option>
            <% marcas.forEach(m => { %>
              <option value="<%= m._id %>"><%= m.nombre %></option>
            <% }) %>
          </select>
        </div>

        <!-- Proveedor -->
        <div class="form-group">
          <label>Proveedor</label>
          <select name="proveedor">
            <option value="">Seleccione un proveedor</option>
            <% proveedores.forEach(p => { %>
              <option value="<%= p._id %>"><%= p.nombre %></option>
            <% }) %>
          </select>
        </div>

        <!-- Imágenes -->
        <div class="form-group full">
          <label>Imágenes del producto (máx 4)</label>
          <input type="file" name="fotos" multiple>
        </div>

      </div>

      <!-- BOTÓN -->
      <div class="form-actions">
        <button type="submit">Crear Producto</button>
      </div>

    </form>

  </div>
</div>

<%- include('../../include/_footerAdmin') %>