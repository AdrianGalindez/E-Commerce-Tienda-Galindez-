<%- include('../../include/_headerAdmin') %>

<div class="page-wrapper">

  <div class="page-header">
    <h1>Crear Nuevo Producto</h1>
    <p>Completa la información del producto para agregarlo al inventario</p>
  </div>

  <div class="form-card">

    <form action="/api/productos" method="POST" enctype="multipart/form-data" class="product-form">

      <!-- GRID PRINCIPAL -->
      <div class="form-grid">

        <!-- Nombre -->
        <div class="form-group full">
          <label>Nombre del producto</label>
          <input type="text" name="nombre" required>
        </div>

        <!-- Descripción -->
        <div class="form-group full">
          <label>Descripción</label>
          <textarea name="descripcion" rows="4" placeholder="Describe el producto..."></textarea>
        </div>

        <!-- Precio costo -->
        <div class="form-group">
          <label>Precio de costo</label>
          <input type="number" step="0.01" name="precioCosto" required>
        </div>

        <!-- Precio venta -->
        <div class="form-group">
          <label>Precio de venta</label>
          <input type="number" step="0.01" name="precioBase" required>
        </div>

        <!-- Unidad Base 🔥 -->
        <div class="form-group">
          <label>Unidad base</label>
          <select name="unidadBase" required>
            <option value="">Seleccione una unidad</option>
            <% unidades.forEach(u => { %>
              <option value="<%= u._id %>"><%= u.nombre %></option>
            <% }) %>
          </select>
        </div>

        <!-- Stock -->
        <div class="form-group">
          <label>Stock</label>
          <input type="number" name="stock" required>
        </div>

        <!-- Categoría -->
        <div class="form-group">
          <label>Categoría</label>
          <select name="categoria" required>
            <option value="">Seleccione una categoría</option>
            <% categorias.forEach(c => { %>
              <option value="<%= c._id %>"><%= c.nombre %></option>
            <% }) %>
          </select>
        </div>

        <!-- Marca -->
        <div class="form-group">
          <label>Marca</label>
          <select name="marca" required>
            <option value="">Seleccione una marca</option>
            <% marcas.forEach(m => { %>
              <option value="<%= m._id %>"><%= m.nombre %></option>
            <% }) %>
          </select>
        </div>

        <!-- Proveedor -->
        <div class="form-group">
          <label>Proveedor</label>
          <select name="proveedor">
            <option value="">Seleccione un proveedor</option>
            <% proveedores.forEach(p => { %>
              <option value="<%= p._id %>"><%= p.nombre %></option>
            <% }) %>
          </select>
        </div>

        <!-- Imágenes -->
        <div class="form-group full">
          <label>Imágenes del producto (máx 4)</label>
          <input type="file" name="fotos" multiple>
        </div>

      </div>

      <!-- 🔥 PRESENTACIONES -->
      <div class="form-group full">
        <label>Precios por presentación</label>

        <div id="presentaciones-container"></div>

        <button type="button" onclick="agregarPresentacion()">
          + Agregar presentación
        </button>
      </div>

      <!-- INPUT OCULTO -->
      <input type="hidden" name="presentaciones" id="presentacionesInput">

      <!-- BOTÓN -->
      <div class="form-actions">
        <button type="submit">Crear Producto</button>
      </div>

    </form>

  </div>
</div>

<!-- 🔥 SCRIPT -->
<script>
let contador = 0;

function agregarPresentacion() {
  const container = document.getElementById('presentaciones-container');

  const div = document.createElement('div');
  div.classList.add('presentacion-item');
  div.style.marginBottom = "10px";

  div.innerHTML = `
    <select class="unidad" required>
      <option value="">Unidad</option>
      <% unidades.forEach(u => { %>
        <option value="<%= u._id %>"><%= u.nombre %></option>
      <% }) %>
    </select>

    <input type="number" class="precio" placeholder="Precio" step="0.01" required>

    <button type="button" onclick="this.parentElement.remove()">X</button>
  `;

  container.appendChild(div);
}

document.querySelector('.product-form').addEventListener('submit', function () {

  const items = document.querySelectorAll('.presentacion-item');

  const data = [];

  items.forEach(item => {
    const unidad = item.querySelector('.unidad').value;
    const precio = item.querySelector('.precio').value;

    if (unidad && precio) {
      data.push({
        unidad,
        precio: Number(precio)
      });
    }
  });

  document.getElementById('presentacionesInput').value = JSON.stringify(data);
});
</script>

<%- include('../../include/_footerAdmin') %>