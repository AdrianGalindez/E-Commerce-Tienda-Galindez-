<%- include('../../include/_headerAdmin') %>

<div class="page-wrapper">

  <div class="page-header">
    <h1>Editar Producto</h1>
    <p>Actualiza la información del producto y gestiona sus imágenes</p>
  </div>

  <div class="form-card">

    <form action="/api/productos/<%= producto._id %>?_method=PUT"
          method="POST"
          enctype="multipart/form-data"
          class="product-form">

      <!-- GRID INFO -->
      <div class="form-grid">

        <div class="form-group full">
          <label>Nombre</label>
          <input type="text" name="nombre" value="<%= producto.nombre %>">
        </div>

        <div class="form-group full">
          <label>Descripción</label>
          <textarea name="descripcion" rows="4"><%= producto.descripcion %></textarea>
        </div>

        <div class="form-group">
          <label>Precio costo</label>
          <input type="number" name="precioCosto" value="<%= producto.precioCosto || 0 %>">
        </div>

        <div class="form-group">
          <label>Precio base</label>
          <input type="number" name="precioBase" value="<%= producto.precioBase || 0 %>">
        </div>

        <div class="form-group">
          <label>Stock</label>
          <input type="number" name="stock" value="<%= producto.stock || 0 %>">
        </div>

        <!-- 🔥 UNIDAD BASE -->
        <div class="form-group">
          <label>Unidad base</label>
          <select name="unidadBase" required>
            <% unidades.forEach(u => { %>
              <option value="<%= u._id %>" 
                <%= producto.unidadBase && producto.unidadBase._id == u._id ? 'selected' : '' %>>
                <%= u.nombre %>
              </option>
            <% }) %>
          </select>
        </div>

      </div>

      <!-- 🔥 PRESENTACIONES -->
      <div class="form-group full">
        <label>Presentaciones (precios por unidad)</label>

        <div id="presentaciones-container">

          <% if(producto.presentaciones && producto.presentaciones.length > 0){ %>

            <% producto.presentaciones.forEach((p, i) => { %>
              <div class="presentacion-item">

                <select class="unidad-select">
                  <% unidades.forEach(u => { %>
                    <option value="<%= u._id %>"
                      <%= p.unidad && p.unidad._id == u._id ? 'selected' : '' %>>
                      <%= u.nombre %>
                    </option>
                  <% }) %>
                </select>

                <input type="number" class="precio-input" value="<%= p.precio %>" placeholder="Precio">

                <button type="button" onclick="eliminarPresentacion(this)">X</button>

              </div>
            <% }) %>

          <% } %>

        </div>

        <button type="button" onclick="agregarPresentacion()">+ Agregar presentación</button>

        <input type="hidden" name="presentaciones" id="presentacionesInput">

      </div>

      <!-- IMÁGENES -->
      <div class="image-section">

        <h2>Imágenes actuales</h2>

        <div class="image-grid">

          <% if(producto.fotos && producto.fotos.length > 0){ %>

            <% producto.fotos.forEach(function(foto, index){ %>

              <div class="image-card">

                <img src="<%= foto %>" alt="producto">

                <div class="image-actions">

                  <input type="file" name="foto_<%= index %>">

                  <label class="delete-check">
                    <input type="checkbox" name="eliminarFotos" value="<%= foto %>">
                    Eliminar
                  </label>

                </div>

              </div>

            <% }) %>

          <% } else { %>
            <p class="empty">Sin imágenes registradas</p>
          <% } %>

        </div>

        <div class="upload-new">
          <h3>Agregar nuevas imágenes</h3>
          <input type="file" name="nuevasFotos" multiple>
        </div>

      </div>

      <!-- BOTÓN -->
      <div class="form-actions">
        <button type="submit">Actualizar Producto</button>
      </div>

    </form>

  </div>
</div>

<!-- 🔥 SCRIPT PRESENTACIONES -->
<script>
function agregarPresentacion() {
  const container = document.getElementById('presentaciones-container');

  const div = document.createElement('div');
  div.classList.add('presentacion-item');

  div.innerHTML = `
    <select class="unidad-select">
      <% unidades.forEach(u => { %>
        <option value="<%= u._id %>"><%= u.nombre %></option>
      <% }) %>
    </select>

    <input type="number" class="precio-input" placeholder="Precio">
    <button type="button" onclick="eliminarPresentacion(this)">X</button>
  `;

  container.appendChild(div);
}

function eliminarPresentacion(btn) {
  btn.parentElement.remove();
}

// 🔥 convertir a JSON antes de enviar
document.querySelector('form').addEventListener('submit', function() {

  const items = document.querySelectorAll('.presentacion-item');

  const data = [];

  items.forEach(item => {
    const unidad = item.querySelector('.unidad-select').value;
    const precio = item.querySelector('.precio-input').value;

    if (unidad && precio) {
      data.push({ unidad, precio });
    }
  });

  document.getElementById('presentacionesInput').value = JSON.stringify(data);
});
</script>

<%- include('../../include/_footerAdmin') %>