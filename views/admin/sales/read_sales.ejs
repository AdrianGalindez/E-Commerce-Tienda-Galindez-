<!-- include header -->
<%- include('include/_headerAdmin') %>
<!-- /include header -->


<main>
<div>
<h1>Gestionar Ventas</h1>
</div>
  <table class="table">
    <thead>
      <tr>
        <th scope="col" hidden>#</th>
        <th scope="col">Fecha</th>
        <th scope="col">Total</th>
        <th scope="col">Editar</th>
        <th scope="col">Eliminar</th>
      </tr>
    </thead>
    <tbody>
      <% sales.forEach(function(sale) { %>
      <tr>
        <th scope="row" hidden><%= sale._id %></th>

        <td>
          <%= new Date(sale.fecha).toLocaleDateString() %>
        </td>

        <td>$ <%= sale.total %></td>

        <td>
          <a href="/update-sale?id=<%= sale._id %>" class="btn btn-success">Editar</a>
        </td>

        <td>
          <a href="/api/sales/<%= sale._id %>" class="btn btn-danger delete">Eliminar</a>
        </td>
      </tr>
      <% }); %>
        <tr>
          <td colspan="4" >
          <a href="/create-ventas-form" class="btn btn-primary">Crear Nueva Venta</a>
        </td>
      </tr>
    </tbody>
  </table>

</main>


<!-- include footer -->
<%- include('include/_footerAdmin') %>
<!-- /include footer -->