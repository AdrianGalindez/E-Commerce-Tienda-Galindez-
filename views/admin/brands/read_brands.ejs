<!-- include header -->
<%- include('../../include/_headerAdmin') %>
<!-- /include header -->


<main>
<div>
<h1>Gestionar Marcas</h1>
</div>


  <table class="table">
    <thead>
      <tr>
        <th scope="col" hidden>#</th>
        <th scope="col">Nombre</th>
        <th scope="col">Imagen</th>
        <th scope="col">Editar</th>
        <th scope="col">Eliminar</th>
      </tr>
    </thead>
    <tbody>
      <% brands.forEach(function(brand) { %>
      <tr>
        <th scope="row" hidden><%= brand._id %></th>
        <td><%= brand.nombre %></td>
        <td>
             <% if (brand.foto) { %>
                 <img src="<%= brand.foto %>" width="80" height="80" style="object-fit: cover;">
             <% } else { %>
                 <span>Sin imagen</span>
             <% } %>
        </td>
        <td>
          <a href="/update-marca?id=<%= brand._id %>" class="btn btn-success">Editar</a>
        </td>

        <td>
          <a href="/delete-marca/<%= brand._id %>" class="btn btn-danger delete">Eliminar</a>
        </td>
      </tr>
      <% }); %>
       <tr>
        <td colspan="4" >
          <a href="/create-marca" class="btn btn-primary">Crear Nueva Marca</a>
        </td>
      </tr>
    </tbody>
  </table>

</main>



<!-- include footer -->
<%- include('../../include/_footerAdmin') %>
<!-- /include footer -->