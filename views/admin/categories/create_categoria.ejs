<%- include('../../include/_headerAdmin') %>

<div class="page-wrapper">

  <div class="page-header">
    <h1>Categorías</h1>
    <p>Crea y organiza las categorías de tus productos</p>
  </div>

  <div class="form-card small-card">

    <% if (locals.error) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <% if (locals.success) { %>
      <div class="alert success"><%= success %></div>
    <% } %>

    <form action="/create-categoria" method="POST" class="category-form">

      <div class="form-group">
        <label>Nombre de la categoría</label>
        <input type="text" name="nombre" placeholder="Ej: Tecnología" required autofocus>
        <small>El nombre debe ser único</small>
      </div>

      <div class="form-actions">
        <button type="submit">Guardar categoría</button>
      </div>

    </form>

  </div>
</div>

<%- include('../../include/_footerAdmin') %>