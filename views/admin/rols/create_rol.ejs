<%- include('../../include/_headerAdmin') %>

<div class="page-wrapper">

  <div class="page-header">
    <h1>Roles</h1>
    <p>Define los roles de acceso del sistema</p>
  </div>

  <div class="form-card small-card">

    <form action="/create-rol" method="POST" class="role-form">

  <div class="form-group">
    <label>Nombre del rol</label>
    <input type="text" name="nombre" placeholder="Ej: Administrador" required>
    <small>Define permisos según este rol</small>
  </div>

  <div class="form-group">
    <label>Descripción</label>
    <textarea 
        name="descripcion" 
        placeholder="Ej: Tiene acceso total al sistema"
        rows="3"
        required>
    </textarea>
    <small>Explica qué hace este rol</small>
  </div>

  <div class="form-actions">
    <button type="submit">Guardar rol</button>
  </div>

</form>

  </div>
</div>

<%- include('../../include/_footerAdmin') %>