<!-- include header -->
<%- include('../../include/_headerAdmin') %>
<!-- /include header -->


<main>
<div>
<h1>Gestionar Usuarios</h1>
</div>
     <table class="table">
  <thead>
    <tr>
      <th scope="col" hidden>#</th>
      <th scope="col">nombre</th>
      <th scope="col">email</th>
      <th scope="col">telefono</th>
      <th scope="col">genero</th>
      <th scope="col">direccion</th>
      <th scope="col">barrio</th>
      <th scope="col">ciudad</th>
      <th scope="col">punto de Referencia</th>
      <th scope="col">ubicacion</th>
      <th scope="col">estado</th>
      <th scope="col">fecha de Registro</th>
      <th scope="col">Editar</th>
      <th scope="col">Eliminar</th>
    </tr>
  </thead>
  <tbody>
    <% users.forEach(function(user) { %>
    <tr>
      <th scope="row" hidden><%= user.id %></th>
      <td><%= user.nombre %></td>
      <td><%= user.email %></td>
      <td><%= user.telefono %></td>
      <td><%= user.genero %></td>
      <td><%= user.direccion %></td>
      <td><%= user.barrio %></td>
      <td><%= user.ciudad %></td>
      <td><%= user.puntoReferencia %></td>
      <td><%= user.ubicacion ? user.ubicacion.lat + ", " + user.ubicacion.lng : "" %></td>
      <td><%= user.estado %></td>
      <td><%= user.fechaRegistro %></td>
      <td><a href="/update-user/<%= user._id %>" class="btn btn-warning">Editar</a></td>
      <td><a href="/delete-user/<%= user._id %>" class="btn btn-danger delete">Eliminar</a></td>
    </tr>
    <% }); %>
      <tr>
          <td colspan="13" >
          <a href="/add-user-form" class="btn btn-primary">Crear Nuevo Usuario</a>
        </td>
      </tr>
  </tbody>
</table>

</main>


<!-- include footer -->
<%- include('../../include/_footerAdmin') %>
<!-- /include footer -->