<%- include('../../include/_headerAdmin') %>

<div class="page-wrapper">

  <div class="page-header">
    <h1>Usuarios</h1>
    <p>Crea nuevos usuarios del sistema con sus datos de contacto</p>
  </div>

  <div class="form-card">

    <form action="/add-user" method="POST" class="user-form">

      <div class="form-grid">

        <!-- Nombre -->
        <div class="form-group full">
          <label>Nombre completo</label>
          <input type="text" name="nombre" required>
        </div>

        <!-- Email -->
        <div class="form-group full">
          <label>Correo electrónico</label>
          <input type="email" name="email" required>
        </div>

        <!-- Teléfono -->
        <div class="form-group">
          <label>Teléfono</label>
          <input type="text" name="telefono" required>
        </div>

        <!-- Género -->
        <div class="form-group">
          <label>Género</label>
          <select name="genero">
            <option value="">Seleccione...</option>
            <option value="Masculino">Masculino</option>
            <option value="Femenino">Femenino</option>
            <option value="Otro">Otro</option>
          </select>
        </div>

        <!-- Dirección -->
        <div class="form-group full">
          <label>Dirección</label>
          <input type="text" name="direccion" required>
        </div>

        <!-- Barrio -->
        <div class="form-group">
          <label>Barrio</label>
          <input type="text" name="barrio">
        </div>

        <!-- Ciudad -->
        <div class="form-group">
          <label>Ciudad</label>
          <input type="text" name="ciudad" value="Bogotá">
        </div>

        <!-- Punto de referencia -->
        <div class="form-group full">
          <label>Punto de referencia</label>
          <input type="text" name="puntoReferencia">
        </div>

        <!-- Estado -->
        <div class="form-group full">
          <label>Estado</label>
          <input type="text" name="estado" value="Activo" readonly>
        </div>

      </div>

      <div class="form-actions">
        <button type="submit">Crear usuario</button>
      </div>

    </form>

  </div>
</div>

<%- include('../../include/_footerAdmin') %>