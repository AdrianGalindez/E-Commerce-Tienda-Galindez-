
<!-- include header -->
    <%- include('include/_header') %>
<!-- /include header -->


    <!-- Main Site -->

        <div class="container">
            <h1>Carrito de Compras</h1>
            <p>Revisa los productos que has agregado a tu carrito de compras y realiza el checkout cuando estés listo.</p>
        </div>     
        
<main class="main-cart">
  <div class="cart-wrapper">
    <section class="items-section">
      <header class="cart-header">
        <h1>Tu Despensa</h1>
        <span class="badge">3 Artículos</span>
      </header>

      <div class="product-list">
        <article class="product-card">
          <div class="img-container">
            <img src="https://images.unsplash.com/photo-1586201375761-83865001e31c?auto=format&fit=crop&q=80&w=150" alt="Arroz">
          </div>
          <div class="product-info">
            <h3>Arroz Grano Largo</h3>
            <p class="category">Cereales y granos</p>
          </div>
          <div class="quantity-picker">
            <button class="qty-btn">-</button>
            <input type="number" value="1" readonly>
            <button class="qty-btn">+</button>
          </div>
          <p class="price">$4.50</p>
          <button class="remove-btn">✕</button>
        </article>
        </div>
    </section>

    <aside class="summary-section">
      <div class="summary-card">
        <h2>Resumen</h2>
        <div class="divider"></div>
        <div class="summary-line">
          <span>Subtotal</span>
          <span>$12.50</span>
        </div>
        <div class="summary-line">
          <span>Envío</span>
          <span class="free">Gratis</span>
        </div>
        <div class="divider"></div>
        <div class="summary-line total">
          <span>Total</span>
          <span class="total-amount">$12.50</span>
        </div>
        <button class="checkout-button">
          Proceder al Pago
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </div>
    </aside>
  </div>
</main>
<!-- /Main Site -->


<!-- include footer -->
<%- include('include/_footer') %>
<!-- /include footer -->
