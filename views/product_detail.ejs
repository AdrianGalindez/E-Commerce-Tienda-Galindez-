<!-- include header -->
<%- include('include/_header') %>
<!-- /include header -->

<div class="container mt-5">

    <div class="row">

        <!-- 🔥 CARRUSEL DE IMÁGENES -->
        <div class="col-md-6">

            <div id="carouselProducto" class="carousel slide">

                <div class="carousel-inner">

                    <% if(product.fotos && product.fotos.length > 0){ %>

                        <% product.fotos.forEach((foto, index) => { %>
                            <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                                <img src="<%= foto %>" class="d-block w-100" style="height:400px; object-fit:cover;">
                            </div>
                        <% }) %>

                    <% } else if(product.foto){ %>

                        <div class="carousel-item active">
                            <img src="<%= product.foto %>" class="d-block w-100" style="height:400px; object-fit:cover;">
                        </div>

                    <% } else { %>

                        <div class="carousel-item active">
                            <img src="/assets/img/default.jpg" class="d-block w-100">
                        </div>

                    <% } %>

                </div>

                <button class="carousel-control-prev" type="button" data-bs-target="#carouselProducto" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>

                <button class="carousel-control-next" type="button" data-bs-target="#carouselProducto" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>

            </div>

        </div>

        <!-- 🧾 INFO DEL PRODUCTO -->
        <div class="col-md-6">

            <h2><%= product.nombre %></h2>

            <p class="text-muted">
                Marca: <strong><%= product.marca?.nombre || 'N/A' %></strong>
            </p>

            <p>
                Categoría: <strong><%= product.categoria?.nombre || 'N/A' %></strong>
            </p>

            <h3 class="text-success">$ <%= product.precio %></h3>

            <p>
                <%= product.descripcion || 'Sin descripción disponible' %>
            </p>

            <ul class="list-group mb-3">
                <li class="list-group-item">
                    Stock disponible: <strong><%= product.stock %></strong>
                </li>
                <li class="list-group-item">
                    Fecha ingreso: <%= product.fechaIngreso %>
                </li>
            </ul>

            <!-- 🛒 BOTONES -->
            <div class="mt-3">
                <form action="/add-to-carrito" method="POST" style="display:inline;">
                    <input type="hidden" name="productoId" value="<%= product._id %>">
                    <button type="submit" class="card-link">🛒 Agregar</button>
                </form> 

                <a href="/" class="btn btn-secondary">
                    Volver
                </a>
            </div>

        </div>

    </div>

</div>



<hr>

<h3>⭐ Reseñas de clientes</h3>

<% if(!reviews || reviews.length === 0){ %>

<p>No hay reseñas todavía</p>

<% } %>

<% reviews.forEach(r => { %>

<div class="card mb-3">

    <div class="card-body">

        <h5>
            ⭐ <%= r.calificacion %> / 5
        </h5>

        <p>
            <%= r.comentario %>
        </p>

        <small>
            Usuario: <%= r.usuario?.nombre || "Anónimo" %>
        </small>

        <!-- fotos de la reseña -->

        <% if(r.fotos && r.fotos.length > 0){ %>

            <div class="mt-2">

                <% r.fotos.forEach(f => { %>

                    <img src="<%= f %>" 
                    style="width:100px;height:100px;object-fit:cover;margin-right:5px;">

                <% }) %>

            </div>

        <% } %>

        <!-- video -->

        <% if(r.video){ %>

            <div class="mt-2">

                <video width="250" controls>
                    <source src="<%= r.video %>" type="video/mp4">
                </video>

            </div>

        <% } %>

    </div>

</div>

<% }) %>

<!-- include footer -->
<%- include('include/_footer') %>
<!-- /include footer -->