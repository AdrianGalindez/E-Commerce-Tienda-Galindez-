<%- include('../../include/_header') %>


<div class="container mt-4">

    <div class="row">


        <!-- CONTENIDO -->
        <div class="col-md-9">

            <div class="profile-card">

                <!-- HEADER -->
                <div class="profile-header text-center">
                    <i class="bi bi-person-circle profile-avatar"></i>
                    <h3><%= user.nombre %></h3>
                    <span class="badge bg-secondary">Cliente</span>
                </div>

                <!-- BOTÓN EDITAR -->
                <div class="text-end mb-3">
                    <button id="editBtn" class="btn btn-dark btn-sm">
                        <i class="bi bi-pencil"></i> Editar
                    </button>
                </div>

                <!-- FORM -->
                <form action="/api/users/<%= user._id %>" method="POST">

                    <!-- Si usas method-override -->
                    <!-- <input type="hidden" name="_method" value="PUT"> -->

                    <div class="profile-info">

                        <div class="info-item">
                            <span>Nombre</span>
                            <p class="view"><%= user.nombre %></p>
                            <input class="form-control edit d-none" name="nombre" value="<%= user.nombre %>">
                        </div>

                        <div class="info-item">
                            <span>Email</span>
                            <p><%= user.email %></p>
                        </div>

                        <div class="info-item">
                            <span>Teléfono</span>
                            <p class="view"><%= user.telefono %></p>
                            <input class="form-control edit d-none" name="telefono" value="<%= user.telefono %>">
                        </div>

                        <div class="info-item">
                            <span>Dirección</span>
                            <p class="view"><%= user.direccion %></p>
                            <input class="form-control edit d-none" name="direccion" value="<%= user.direccion %>">
                        </div>

                        <div class="info-item">
                            <span>Ciudad</span>
                            <p class="view"><%= user.ciudad %></p>
                            <input class="form-control edit d-none" name="ciudad" value="<%= user.ciudad %>">
                        </div>

                        <div class="info-item">
                            <span>Barrio</span>
                            <p class="view"><%= user.barrio %></p>
                            <input class="form-control edit d-none" name="barrio" value="<%= user.barrio %>">
                        </div>

                    </div>

                    <!-- BOTONES -->
                    <div class="text-end mt-3 d-none" id="saveSection">
                        <button type="submit" class="btn btn-success btn-sm">
                            Guardar cambios
                        </button>
                        <button type="button" id="cancelBtn" class="btn btn-secondary btn-sm">
                            Cancelar
                        </button>
                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

<script>
    const editBtn = document.getElementById('editBtn');
    const cancelBtn = document.getElementById('cancelBtn');
    const edits = document.querySelectorAll('.edit');
    const views = document.querySelectorAll('.view');
    const saveSection = document.getElementById('saveSection');

    editBtn.addEventListener('click', () => {
        edits.forEach(e => e.classList.remove('d-none'));
        views.forEach(v => v.classList.add('d-none'));
        saveSection.classList.remove('d-none');
        editBtn.classList.add('d-none');
    });

    cancelBtn.addEventListener('click', () => {
        edits.forEach(e => e.classList.add('d-none'));
        views.forEach(v => v.classList.remove('d-none'));
        saveSection.classList.add('d-none');
        editBtn.classList.remove('d-none');
    });
</script>

<%- include('../../include/_footer') %>