<%- include('include/_headerAdmin') %>

<h1>Editar Producto</h1>

<form action="/api/productos/<%= producto._id %>?_method=PUT" method="POST" enctype="multipart/form-data">

  <!-- NOMBRE -->
  <label>Nombre</label>
  <input type="text" name="nombre" value="<%= producto.nombre %>" />

  <!-- DESCRIPCIÓN -->
  <label>Descripción</label>
  <textarea name="descripcion"><%= producto.descripcion %></textarea>

  <!-- PRECIOS -->
  <label>Precio Costo</label>
  <input type="number" name="precioCosto" value="<%= producto.precioCosto %>" />

  <label>Precio Venta</label>
  <input type="number" name="precio" value="<%= producto.precio %>" />

  <!-- STOCK -->
  <label>Stock</label>
  <input type="number" name="stock" value="<%= producto.stock %>" />

  <!-- ================= IMÁGENES ================= -->
  <h3>Imágenes actuales</h3>

  <div style="display:flex; gap:10px; flex-wrap:wrap;">
    <% if(producto.fotos && producto.fotos.length > 0){ %>
      <% producto.fotos.forEach(function(foto, index){ %>

        <div>
          <img src="<%= foto %>" width="100"><br>

          <!-- Reemplazar imagen específica -->
          <input type="file" name="foto_<%= index %>">

          <!-- Eliminar -->
          <label>
            <input type="checkbox" name="eliminarFotos" value="<%= foto %>">
            Eliminar
          </label>
        </div>

      <% }) %>
    <% } else { %>
      <p>Sin imágenes</p>
    <% } %>
  </div>

  <!-- AGREGAR NUEVAS -->
  <h3>Agregar nuevas imágenes</h3>
  <input type="file" name="nuevasFotos" multiple>

  <br><br>
  <button type="submit">Actualizar</button>

</form>

<%- include('include/_footerAdmin') %>