
<!-- include header -->
    <%- include('include/_header') %>
<!-- /include header -->


    <!-- Main Site -->
    <main id="site-main">
        <div class="container">
            <h1>Marcas</h1>
        </div>
        <p>Descubre las mejores marcas de productos de aseo para tu hogar. Desde detergentes hasta productos de limpieza, tenemos todo lo que necesitas para mantener tu casa impecable.</p>
        <% marcas.forEach(m => { %>
            <div class="product">
                <h3><%= m.nombre %></h3>
            </div>
        <% }) %>
        <div class="card" style="width: 18rem;">
          <img src="..." class="card-img-top" alt="...">
          <div class="card-body">
            <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card’s content.</p>
          </div>
        </div>
        
    </main>
    <!-- /Main Site -->


<!-- include footer -->
<%- include('include/_footer') %>
<!-- /include footer -->