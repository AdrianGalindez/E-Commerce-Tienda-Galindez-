<%- include('include/_headerAdmin') %>

<div class="container mt-4">
    <h2><i class="bi bi-cart-check"></i> Listado de Ventas</h2>
    <hr>

    <% if (ventas && ventas.length > 0) { %>
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID Venta</th>
                        <th>Fecha</th>
                        <th>Total</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% ventas.forEach(venta => { %>
                        <tr>
                            <td><%= venta._id %></td>
                            <td><%= new Date(venta.fecha).toLocaleDateString() %></td>
                            <td>$<%= venta.total.toFixed(2) %></td>
                            <td>
                                <button class="btn btn-sm btn-info" type="button" data-bs-toggle="collapse" data-bs-target="#detalle-<%= venta._id %>" aria-expanded="false">
                                    <i class="bi bi-eye"></i> Ver detalles
                                </button>
                            </td>
                        </tr>
                        <tr class="collapse" id="detalle-<%= venta._id %>">
                            <td colspan="4">
                                <div class="card card-body">
                                    <h6>Detalles de la venta</h6>
                                    <table class="table table-sm">
                                        <thead>
                                            <tr>
                                                <th>Producto</th>
                                                <th>Cantidad</th>
                                                <th>Precio Unit.</th>
                                                <th>Subtotal</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (venta.detalles && venta.detalles.length > 0) { %>
                                                <% venta.detalles.forEach(det => { %>
                                                    <tr>
                                                        <td><%= det.producto ? det.producto.nombre : 'Producto no encontrado' %></td>
                                                        <td><%= det.cantidad %></td>
                                                        <td>$<%= det.precioUnitario.toFixed(2) %></td>
                                                        <td>$<%= (det.cantidad * det.precioUnitario).toFixed(2) %></td>
                                                    </tr>
                                                <% }); %>
                                            <% } else { %>
                                                <tr><td colspan="4" class="text-muted">No hay detalles</td></tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="alert alert-info">No hay ventas registradas.</div>
    <% } %>
</div>

<%- include('include/_footerAdmin') %>
