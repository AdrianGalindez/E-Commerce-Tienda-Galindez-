<!-- include header -->
<%- include('include/_headerAdmin') %>
<!-- /include header -->




<main>
<div>
<h1>Gestionar Roles</h1>
</div>
  <table class="table">
    <thead>
      <tr>
        <th scope="col" hidden>#</th>
        <th scope="col">Nombre</th>
        <th scope="col">Descripción</th>
        <th scope="col">Editar</th>
        <th scope="col">Eliminar</th>
      </tr>
    </thead>
    <tbody>
      <% roles.forEach(function(rol) { %>
      <tr>
        <th scope="row" hidden><%= rol._id %></th>
        <td><%= rol.nombre %></td>
        <td><%= rol.descripcion %></td>

        <td>
          <a href="/update-rol?id=<%= rol._id %>" class="btn btn-success">Editar</a>
        </td>

        <td>
          <a href="/delete-rol/<%= rol._id %>" class="btn btn-danger delete">Eliminar</a>
        </td>
      </tr>
      <% }); %>
            <tr>
        <td colspan="4" >
          <a href="/create-rol" class="btn btn-primary">Crear Nuevo Rol</a>
        </td>
      </tr>
    </tbody>
  </table>

</main>

<!-- include footer -->
